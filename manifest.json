{
  "manifest_version": 3,
  "name": "Ask CPT",
  "version": "1.0",
  "description": "Your ultimate AI Coding Assistant for solving algorithm problems in real-time.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://openrouter.ai/api/v1/*",
    "https://api.groq.com/*",
    "https://api.openai.com/*",
    "https://api.together.xyz/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://leetcode.com/*",
        "*://*.leetcode.com/*"
      ],
      "js": [
        "config.js",
        "domParser.js",
        "aiClient.js",
        "ui.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "editorWriter.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ]
}